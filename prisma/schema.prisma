generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Paciente {
  telefone                String                 @id
  nomeCompleto            String
  senhaHash               String
  dataCadastro            DateTime               @default(now())
  alturaM                 Float?                 @map("altura_m")
  isSubscriber            Boolean                @default(false) @map("is_subscriber")
  subscriptionStartedAt   DateTime?              @map("subscription_started_at")
  subscriptionCanceledAt  DateTime?              @map("subscription_canceled_at")
  apiKey                  String?                @unique @map("api_key")

  historicoPesos          HistoricoPeso[]
  questionariosConcluidos QuestionarioConcluido[]
  answers                 Answer[]

  @@map("pacientes")
}

model HistoricoPeso {
  id               Int      @id @default(autoincrement())
  pacienteTelefone String   @map("paciente_telefone")
  pesoKg           Float
  imc              Float?
  dataRegistro     DateTime @default(now())

  paciente         Paciente @relation(fields: [pacienteTelefone], references: [telefone])

  @@map("historico_pesos")
}

model Pilar {
  id              Int                 @id @default(autoincrement())
  nomePilar       String              @unique @map("nome_pilar")
  descricao       String?
  pontuacaoMaxima Int                 @map("pontuacao_maxima")

  perguntas       Pergunta[]
  pontuacoes      PontuacaoPorPilar[]

  @@map("pilares")
}

model Pergunta {
  id            Int      @id @default(autoincrement())
  pilarId       Int
  textoPergunta String   @map("texto_pergunta")
  ordem         Int
  ehInvertida   Boolean  @default(false) @map("eh_invertida")

  pilar         Pilar    @relation(fields: [pilarId], references: [id])

  @@map("perguntas")
}

model QuestionarioConcluido {
  id               Int                 @id @default(autoincrement())
  pacienteTelefone String              @map("paciente_telefone")
  pontuacaoTotal   Int                 @map("pontuacao_total")
  percentualGlobal Float               @map("percentual_global")
  classificacao    String
  dataConclusao    DateTime            @default(now()) @map("data_conclusao")

  paciente         Paciente            @relation(fields: [pacienteTelefone], references: [telefone])
  pontuacoes       PontuacaoPorPilar[]
  answers          Answer[]

  @@unique([pacienteTelefone, dataConclusao], name: "unique_monthly_submission")
  @@map("questionarios_concluidos")
}

model PontuacaoPorPilar {
  id                      Int                    @id @default(autoincrement())
  questionarioConcluidoId Int                    @map("questionario_concluido_id")
  pilarId                 Int
  pontuacaoObtida         Int                    @map("pontuacao_obtida")

  questionarioConcluido   QuestionarioConcluido  @relation(fields: [questionarioConcluidoId], references: [id])
  pilar                   Pilar                  @relation(fields: [pilarId], references: [id])

  @@map("pontuacoes_por_pilar")
}

model Answer {
  id                      Int                    @id @default(autoincrement())
  pacienteTelefone        String                 @map("patient_id")
  questionarioConcluidoId Int?                   @map("questionario_concluido_id")
  questionText            String                 @map("question_text")
  answerValue             Int                    @map("answer_value")
  pilarCategory           String                 @map("pilar_category")
  createdAt               DateTime               @default(now()) @map("created_at")

  paciente                Paciente               @relation(fields: [pacienteTelefone], references: [telefone])
  questionarioConcluido   QuestionarioConcluido? @relation(fields: [questionarioConcluidoId], references: [id])

  @@index([pacienteTelefone, createdAt], map: "answers_patient_id_created_at_idx")
  @@index([pilarCategory], map: "answers_pilar_category_idx")
  @@map("answers")
}
